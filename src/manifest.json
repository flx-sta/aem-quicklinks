{
  "manifest_version": 3,
  "name": "AEM Quicklinks",
  "description": "Fast navigation between AEM editing environments — Preview, Editor, Properties, and CRXDE",
  "version": "<PKG_VERSION>",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AEM Quicklinks"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+A",
        "mac": "Alt+A"
      },
      "description": "Open AEM Quicklinks popup"
    }
  },
  "permissions": [
    "activeTab",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "aem-quicklinks@flx-sta"
    }
  }
}